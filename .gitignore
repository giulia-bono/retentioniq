# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
*.so
.eggs/
*.whl

# Virtual environments
.venv/
venv/
env/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Secrets & credentials
.env
.env.*
!.env.example

# Data — raw dumps and feature CSVs are large and may contain PII
data/raw/
data/clean/
data/interim/
data/features/*.csv
data/features/*.parquet

# Trained model binaries (large — use artifact storage in prod)
# JSON parameter files ARE committed (small, human-readable, reproducible)
data/models/
models/
*.pkl
*.joblib
!data/models/*.json

# macOS
.DS_Store

# IDE
.vscode/
.idea/

# Logs
*.log
logs/

# Coverage & testing
.coverage
htmlcov/
.pytest_cache/

# uv / poetry lockfiles (keep pyproject.toml, ignore lockfile if preferred)
# Uncomment below if you don't want to commit the lock file:
# uv.lock
# poetry.lock
